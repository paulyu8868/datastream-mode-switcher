# 이 파일을 복사해서 ".env" 로 저장한 뒤 실제 값을 채우세요. (.env 는 커밋 금지 — .gitignore에 포함)
# rest-scripts/*.py 와 salesforce/scripts/deploy.py 가 이 값을 사용합니다.

# Salesforce My Domain 로그인 URL (예: https://YOUR_MYDOMAIN.my.salesforce.com)
# 개발/스크래치 org 은 보통 https://<name>.develop.my.salesforce.com 형태
SF_LOGIN_URL=

# Connected App 의 Consumer Key / Consumer Secret
SF_CLIENT_ID=
SF_CLIENT_SECRET=

# ---- Client Credentials Flow 로 쓸 경우: 위 두 개만 있으면 됨 ----
# (Connected App 에서 Client Credentials Flow 활성화 + Run As 유저 지정 필요)

# ---- Username-Password Flow 로 쓸 경우에만 아래도 채움 ----
SF_USERNAME=
# 비밀번호 + 보안토큰을 이어붙여 입력
SF_PASSWORD_AND_TOKEN=
